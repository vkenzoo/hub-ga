# ============================================================
# HUB CENTRAL — Template de variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commitar .env.local
# ============================================================

# --- Hub Supabase (escolha staging ou production) ---
HUB_SUPABASE_URL=https://xxxxx.supabase.co
HUB_SUPABASE_ANON_KEY=eyJ...
HUB_SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret — só backend

# --- Gateways ---
ASSINY_WEBHOOK_SECRET=changeme         # secret HMAC do Assiny
HOTMART_WEBHOOK_SECRET=changeme        # HotTok do Hotmart

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM="Vinny <no-reply@mail.exemplo.com>"

# --- Service role keys dos sistemas downstream (Fase 3) ---
SCALO_SUPABASE_URL=
SCALO_SERVICE_ROLE_KEY=
GA_SALES_SUPABASE_URL=
GA_SALES_SERVICE_ROLE_KEY=
BLACKBELT_SUPABASE_URL=
BLACKBELT_SERVICE_ROLE_KEY=

# --- Senha inicial de usuários provisionados ---
DEFAULT_PROVISION_PASSWORD="#Umahoravaidarbom"

# --- Cron / public-api ---
CRON_SECRET=changeme
PUBLIC_API_SHARED_SECRET=changeme
